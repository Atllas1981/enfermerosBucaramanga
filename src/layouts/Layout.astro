---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

/* =========================
   ESTRATEGIA SEO AGRESIVO
========================= */
const {
  // Título optimizado con palabras clave de alta intención
  title = "Enfermeros a Domicilio en Bucaramanga | Cuidado Profesional 24/7",
  // Descripción que ataca el dolor del cliente: precio y rapidez
  description = "Servicio de enfermería profesional en Bucaramanga. Hasta 50% más económico que agencias. Especialistas en adulto mayor y postoperatorios. ¡Atención inmediata!",
  image = "/og/default-og-v2.jpg",
} = Astro.props;

/* =========================
   CONFIGURACIÓN DE RUTAS (GitHub Pages)
========================= */
const getAssetPath = (path: string) =>
  `${import.meta.env.BASE_URL}/${path}`.replace(/(?<!:)\/+/g, "/");

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const absoluteImage = new URL(getAssetPath(image), Astro.site).href;

// Configuración de WhatsApp
const whatsappNumber = "573017205354";
const whatsappMessage = encodeURIComponent(
  "Hola, necesito una cotización para servicio de enfermería a domicilio en Bucaramanga.",
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

/* =========================
   JSON-LD: ESQUEMA DE NEGOCIO LOCAL (Para Google)
========================= */
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness", // O "MedicalBusiness" si prefieres
  "name": "Enfermeros Bucaramanga",
  "alternateName": "Servicios de Enfermería Samuel",
  "description": description,
  "url": canonicalUrl,
  "telephone": `+${whatsappNumber}`,
  "priceRange": "COP",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bucaramanga",
    "addressRegion": "Santander",
    "addressCountry": "CO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 7.1193,
    "longitude": -73.1227
  },
  "areaServed": [
    "Bucaramanga",
    "Floridablanca",
    "Girón",
    "Piedecuesta"
  ],
  "openingHours": "Mo-Su 00:00-23:59"
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <!-- =========================
         META BÁSICOS
    ========================== -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- =========================
         DATOS ESTRUCTURADOS (SEO INVISIBLE)
    ========================== -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessSchema)} />

    <!-- =========================
         OPEN GRAPH (WhatsApp / FB)
    ========================== -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Enfermeros Profesionales Bucaramanga" />

    <!-- =========================
         TWITTER CARD
    ========================== -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <!-- =========================
         ICONOS
    ========================== -->
    <link rel="icon" type="image/svg+xml" href={getAssetPath("favicon.svg")} />
    <link rel="apple-touch-icon" sizes="180x180" href={getAssetPath("apple-touch-icon.png")} />
  </head>

  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <main>
      <slot />
    </main>

    <!-- BOTÓN DE WHATSAPP FLOTANTE (Optimizado para Conversión) -->
    <a
      href={whatsappUrl}
      class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-[0_10px_25px_rgba(37,211,102,0.4)] hover:scale-110 active:scale-95 transition-all duration-300 flex items-center justify-center group"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Pedir enfermera por WhatsApp"
    >
      <!-- Tooltip que aparece al pasar el mouse (solo en desktop) -->
      <span class="absolute right-16 bg-white text-gray-800 text-sm font-bold px-3 py-1 rounded-lg shadow-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none hidden md:block">
        ¿Necesitas ayuda? ¡Escríbenos!
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
      </svg>
    </a>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    text-rendering: optimizeLegibility;
  }
  /* Mejorar el enfoque para accesibilidad */
  :focus-visible {
    outline: 2px solid hsl(205 65% 45%);
    outline-offset: 4px;
  }
</style>