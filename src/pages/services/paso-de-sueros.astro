---
import Layout from "../../layouts/Layout.astro";
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";

const title = "Paso de Sueros a Domicilio en Bucaramanga";
const subtitle = "Hidratación y Medicación Intravenosa en Casa";
const description = "El paso de sueros o terapia intravenosa domiciliaria permite administrar líquidos, electrolitos y medicamentos directamente al torrente sanguíneo de manera segura y controlada. Este servicio es ideal para rehidratación, administración de antibióticos, analgésicos, vitaminas o tratamientos que requieren vía intravenosa. Nuestros enfermeros profesionales garantizan una canalización exitosa, monitoreo constante y manejo de posibles complicaciones.";
const benefits = [
  "Canalización venosa con técnica estéril y materiales desechables",
  "Administración de soluciones según prescripción médica exacta",
  "Monitoreo continuo de signos vitales durante la infusión",
  "Manejo de goteo y tiempo de administración preciso",
  "Identificación temprana de flebitis, infiltración o reacciones adversas",
  "Retiro seguro del catéter y curación del sitio de punción",
  "Enfermeros con experiencia en accesos venosos difíciles"
];
---

<Layout>
  <ServicePageTemplate
    title={title}
    subtitle={subtitle}
    description={description}
    benefits={benefits}
  >
    <div slot="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-white">
        <path d="M12 22a7 7 0 0 1-7-7c0-2 1-3.9 3-5.5C10 8 12 6 12 6s2 2 4 3.5c2 1.6 3 3.5 3 5.5a7 7 0 0 1-7 7z"/>
      </svg>
    </div>
  </ServicePageTemplate>

  <Footer />
  <WhatsAppButton />
</Layout>