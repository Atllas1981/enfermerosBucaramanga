---
import Layout from "../../layouts/Layout.astro";
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";

const title = "Paso de Sondas (Vesicales, Nasogástricas y Nefrostomía) a Domicilio en Bucaramanga";
const subtitle = "Atención Profesional, Segura y Humanizada";
const description = "Ofrecemos el servicio de paso de sondas en casa para pacientes que requieren dispositivos vesicales, nasogástricos o nefrostomías. Cada atención es realizada por personal certificado que garantiza un acompañamiento respetuoso, seguro y con medidas de bioseguridad, ideal para personas con movilidad reducida, condiciones neurológicas o necesidades clínicas específicas.";

const ogImage = "/og/sondas-vesicales.jpg";

const benefits = [
  "Atención profesional para sondas vesicales, nasogástricas y nefrostomías",
  "Uso de técnica estéril y materiales certificados",
  "Selección adecuada del dispositivo según las necesidades del paciente",
  "Manejo cuidadoso para favorecer el confort y reducir molestias",
  "Fijación correcta y verificación del dispositivo",
  "Orientación al paciente y familia sobre cuidados generales",
  "Aplicación de protocolos actualizados para prevenir complicaciones",
  "Acompañamiento posterior según indicación profesional"
];
---

<Layout
  title={title}
  description={description}
  image={ogImage}
>
  <ServicePageTemplate
    title={title}
    subtitle={subtitle}
    description={description}
    benefits={benefits}
  >
    <div slot="icon">
      <!-- Icono general de servicios clínicos -->
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-white">
        <path d="M12 2v20M2 12h20" />
      </svg>
    </div>
  </ServicePageTemplate>

  <Footer />
  <WhatsAppButton />
</Layout>
