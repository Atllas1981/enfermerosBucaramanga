---
import Layout from "../../layouts/Layout.astro";
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";

const title = "Procedimientos Personalizados a Domicilio en Bucaramanga";
const subtitle = "Servicios de Enfermería Adaptados a tus Necesidades Específicas";
const description = "Entendemos que cada paciente es único y puede requerir procedimientos o cuidados especializados que no están listados en los servicios estándar. Ya sea un procedimiento específico indicado por tu médico, combinación de varios servicios, o cuidados especiales post-operatorios, nuestros enfermeros profesionales se adaptan a tus necesidades. Nos especializamos en encontrar soluciones personalizadas para casos complejos o situaciones especiales.";

const benefits = [
  "Evaluación personalizada de tus necesidades específicas de cuidado",
  "Coordinación directa con tu médico tratante para seguir indicaciones precisas",
  "Flexibilidad para combinar múltiples procedimientos en una sola visita",
  "Atención a casos especiales o poco comunes con enfoque individualizado",
  "Especialmente útil para recuperación post-cirugía estética compleja",
  "Servicios adaptados para pacientes internacionales en Bucaramanga",
  "Sin intermediarios: comunicación directa contigo para entender mejor tu caso"
];
---

<Layout
  title={title}
  description={description}
  image="/og/default.jpg" <!-- opcional, si tienes una imagen OG -->

  <ServicePageTemplate
    title={title}
    subtitle={subtitle}
    description={description}
    benefits={benefits}
    heroImage="img/services/default.webp">
  
    <!-- ❌ Sin slot "icon" para evitar el círculo/ícono en el Hero -->
  </ServicePageTemplate>

  <Footer />
  <WhatsAppButton />
</Layout>