---
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import Layout from "../../layouts/Layout.astro";  

const title = "Curaciones a Domicilio en Bucaramanga";
const subtitle = "Enfermería Profesional y Segura para el Cuidado de tus Heridas";
const description = "Las curaciones domiciliarias son procedimientos esenciales para la correcta cicatrización de heridas quirúrgicas, úlceras, quemaduras y lesiones cutáneas. Nuestros enfermeros profesionales realizan el cambio de apósitos, limpieza de heridas y seguimiento de la evolución con técnicas estériles y protocolos actualizados del Ministerio de Salud de Colombia.";

const ogImage = "/og/curaciones.jpg";

const benefits = [
  "Evaluación completa de la herida y registro fotográfico de evolución",
  "Limpieza con técnica aséptica y materiales estériles certificados",
  "Cambio de apósitos especializados según tipo de herida",
  "Identificación temprana de signos de infección o complicaciones",
  "Enfermeros con experiencia en curaciones complejas y post-quirúrgicas",
  "Atención en la comodidad de tu hogar en Bucaramanga y área metropolitana",
  "Comunicación directa con tu médico tratante si se requiere"
];
---

<Layout
  title={title}
  description={description}
  image={ogImage}
>
  <ServicePageTemplate
    title={title}
    subtitle={subtitle}
    description={description}
    benefits={benefits}
  >
    <div slot="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-white">
        <path d="M4 7V4a2 2 0 0 1 2-2h2"/><path d="M12 4v16"/><path d="M4 12h16"/><path d="M16 20h2a2 2 0 0 0 2-2v-2"/>
      </svg>
    </div>
  </ServicePageTemplate>

  <Footer />
  <WhatsAppButton />
</Layout>
