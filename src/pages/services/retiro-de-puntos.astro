---
import Layout from "../../layouts/Layout.astro";
import ServicePageTemplate from "../../components/ServicePageTemplate.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";

const title = "Retiro de Puntos a Domicilio en Bucaramanga";
const subtitle = "Remoción Segura de Suturas Post-Quirúrgicas";
const description = "El retiro de puntos o suturas es un procedimiento delicado que debe realizarse en el momento adecuado y con técnica correcta para evitar dehiscencia de heridas o cicatrices inadecuadas. Nuestros enfermeros profesionales evalúan el estado de cicatrización, retiran cada punto con cuidado y realizan la curación final. Ideal para pacientes post-cirugía estética, cirugías generales o heridas traumáticas que ya cumplieron su tiempo de cicatrización.";

const ogImage = "/og/retiroDePuntos.jpg";

const benefits = [
  "Evaluación previa del estado de cicatrización de la herida",
  "Retiro cuidadoso de suturas con instrumental estéril",
  "Limpieza y curación final del sitio quirúrgico",
  "Identificación de signos de dehiscencia o complicaciones",
  "Especialmente recomendado para cirugías estéticas donde la cicatriz es importante",
  "Recomendaciones de cuidado post-retiro para cicatrización óptima",
  "Evita desplazamientos innecesarios cuando ya estás en recuperación en casa"
];
---

<Layout
  title={title}
  description={description}
  image={ogImage}
>
  <ServicePageTemplate
    title={title}
    subtitle={subtitle}
    description={description}
    benefits={benefits}
  >
    <div slot="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-white">
        <circle cx="6" cy="6" r="3"/>
        <circle cx="6" cy="18" r="3"/>
        <line x1="20" y1="4" x2="8.12" y2="15.88"/>
        <line x1="14.47" y1="14.48" x2="20" y2="20"/>
      </svg>
    </div>
  </ServicePageTemplate>

  <Footer />
  <WhatsAppButton />
</Layout>
