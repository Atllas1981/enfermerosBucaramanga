---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  benefits: string[];
}
const { title, subtitle, description, benefits } = Astro.props;

const phoneNumber = "573001234567";
const message = encodeURIComponent(`Hola, necesito información sobre ${title.toLowerCase()}`);
---

<main class="min-h-screen bg-[hsl(0_0%_100%)]">
  <!-- Header with back button -->
  <div style="background: linear-gradient(135deg, hsl(205 65% 35%) 0%, hsl(205 65% 45%) 100%);" class="text-white py-6">
    <div class="container mx-auto px-4">
      <a href="/enfermerosBucaramanga/" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors mb-4">
        <!-- ArrowLeft SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver al inicio
      </a>
    </div>
  </div>

  <!-- Hero Section -->
  <section style="background: linear-gradient(135deg, hsl(205 65% 35%) 0%, hsl(205 65% 45%) 100%);" class="text-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center animate-fade-in">
        <div class="flex justify-center mb-6">
          <div class="h-20 w-20 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center">
            <slot name="icon" />
          </div>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          {title}
        </h1>
        <p class="text-xl md:text-2xl text-white/90 mb-8">
          {subtitle}
        </p>
        <a
          href={`https://wa.me/${phoneNumber}?text=${message}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-[hsl(142_74%_50%)] hover:bg-[hsl(142_74%_43%)] text-white font-semibold px-6 py-4 rounded-full shadow-[0_20px_40px_-10px_hsl(210_20%_20%_/_0.15)] transition-all"
        >
          <!-- MessageCircle SVG -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 mr-2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Solicitar Servicio por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Description Section -->
  <section class="py-16 bg-[hsl(0_0%_100%)]">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="p-8 md:p-12 border border-[hsl(210_20%_90%)] rounded-lg shadow-[0_10px_30px_-5px_hsl(210_20%_20%_/_0.12)] animate-slide-up bg-[hsl(0_0%_100%)]">
          <h2 class="text-3xl font-bold text-[hsl(210_20%_20%)] mb-6">
            ¿Qué incluye este servicio?
          </h2>
          <p class="text-lg text-[hsl(210_15%_45%)] leading-relaxed mb-8">
            {description}
          </p>

          <div class="space-y-4">
            {benefits.map((benefit) => (
              <div class="flex items-start gap-3">
                <!-- CheckCircle SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-[hsl(145_60%_45%)] flex-shrink-0 mt-1">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <p class="text-[hsl(210_15%_45%)]">{benefit}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="py-16 bg-[hsl(30_15%_95%)]">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-[hsl(210_20%_20%)] mb-6">
          Tu seguridad es nuestra prioridad
        </h2>
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="p-6 bg-[hsl(0_0%_100%)] border border-[hsl(210_20%_90%)] rounded-lg">
            <div class="text-4xl mb-3">🏥</div>
            <h3 class="font-semibold mb-2 text-[hsl(210_20%_20%)]">Enfermeros Certificados</h3>
            <p class="text-sm text-[hsl(210_15%_45%)]">
              Tarjeta profesional vigente y habilitados por el Ministerio de Salud
            </p>
          </div>
          <div class="p-6 bg-[hsl(0_0%_100%)] border border-[hsl(210_20%_90%)] rounded-lg">
            <div class="text-4xl mb-3">✨</div>
            <h3 class="font-semibold mb-2 text-[hsl(210_20%_20%)]">Material Estéril</h3>
            <p class="text-sm text-[hsl(210_15%_45%)]">
              Todos los insumos cumplen protocolos de bioseguridad
            </p>
          </div>
          <div class="p-6 bg-[hsl(0_0%_100%)] border border-[hsl(210_20%_90%)] rounded-lg">
            <div class="text-4xl mb-3">📋</div>
            <h3 class="font-semibold mb-2 text-[hsl(210_20%_20%)]">Registro Clínico</h3>
            <p class="text-sm text-[hsl(210_15%_45%)]">
              Documentación de cada procedimiento realizado
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="background: linear-gradient(135deg, hsl(145 60% 45%), hsl(145 60% 55%));" class="py-16 text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center animate-fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          ¿Necesitas {title.toLowerCase()} en Bucaramanga, Floridablanca, Girón o Piedecuesta?
        </h2>
        <p class="text-xl mb-8 text-white/90">
          Estamos listos para atenderte con profesionalismo, calidez y seguridad. Escríbenos ahora.
        </p>
        <a
          href={`https://wa.me/${phoneNumber}?text=${message}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-white text-[hsl(205_65%_35%)] hover:bg-white/90 font-semibold px-6 py-4 rounded-full shadow-[0_20px_40px_-10px_hsl(210_20%_20%_/_0.15)] transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 mr-2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </section>
</main>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
  .animate-slide-up {
    animation: slide-up 0.6s ease-out forwards;
    opacity: 0;
  }
</style>