---
/* Componente: Sueroterapia Post-Party (SEO Agresivo) */
---

<section
  role="region"
  aria-labelledby="cta-sueroterapia"
  class="relative z-10 overflow-hidden py-24 px-8 mt-20 bg-cover bg-center lg:bg-[position:50%_15%] shadow-2xl"
  style={`background-image: url('${import.meta.env.BASE_URL}/img/services/resaca2.webp');`}
>
  <!-- Overlay más profundo para legibilidad premium -->
  <div class="absolute inset-0 bg-slate-900/70" aria-hidden="true"></div>

  <div class="relative container mx-auto">
    <div class="-mx-4 flex flex-wrap items-center">
      <!-- Texto: Dejamos de preguntar y empezamos a solucionar -->
      <div class="w-full px-4 lg:w-3/5">
        <div class="text-center lg:text-left">
          <h2
            id="cta-sueroterapia"
            class="mb-6 text-3xl font-extrabold leading-tight sm:text-4xl md:text-[44px] text-white"
          >
            Sueroterapia a Domicilio en Bucaramanga: Recuperación Inmediata
          </h2>

          <p class="text-lg font-medium sm:text-xl text-blue-100 max-w-2xl">
            Protocolos de rehidratación avanzada y vitaminas para eliminar el guayabo, 
            agotamiento físico o deshidratación. **Atención profesional en casa.**
          </p>
        </div>
      </div>

      <!-- Botón CTA: Más directo al beneficio -->
      <div class="w-full px-4 lg:w-2/5 mt-10 lg:mt-0">
        <div class="text-center lg:text-right">
          <a
            href={`${import.meta.env.BASE_URL}/services/sueroterapia-post-party`}
            aria-label="Ver servicio de sueroterapia post party a domicilio"
            class="inline-flex items-center justify-center rounded-xl
              bg-white text-indigo-900
              py-5 px-10 font-bold text-lg
              transition-all duration-300
              hover:bg-indigo-50 hover:scale-[1.05] shadow-lg
              focus:outline-none focus:ring-4 focus:ring-indigo-400"
          >
            ¡Solicitar Mi Suero Ya!
          </a>
          <p class="text-white/80 text-sm mt-3 font-medium">Llegamos en menos de 60 min</p>
        </div>
      </div>
    </div>
  </div>
</section>