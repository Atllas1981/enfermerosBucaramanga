---
const services = [
  { title: "Curaciones", slug: "curaciones", img: "curaciones.webp", desc: "Cambio de apósitos y manejo experto de heridas quirúrgicas con técnica estéril." },
  { title: "Inyectología", slug: "inyectologia", img: "inyectologia.webp", desc: "Aplicación segura de medicamentos intramusculares y subcutáneos en su hogar." },
  { title: "Paso de Sueros", slug: "paso-de-sueros", img: "paso-de-sueros.webp", desc: "Hidratación y medicación intravenosa con monitoreo profesional constante." },
  { title: "Nebulizaciones", slug: "nebulizaciones", img: "nebulizaciones.webp", desc: "Terapia respiratoria especializada para el alivio de afecciones pulmonares." },
  { title: "Retiro de Puntos", slug: "retiro-de-puntos", img: "retiro-de-puntos.webp", desc: "Remoción segura de suturas con evaluación profesional de la cicatrización." },
  { title: "Paso de Sondas", slug: "sondas-vesicales", img: "paso-de-sondas.webp", desc: "Instalación y manejo experto de sondas vesicales y gástricas en casa." },
  { title: "Manejo de Colostomías", slug: "colostomias", img: "manejo-de-colostomias.webp", desc: "Cuidado integral y educación en el manejo de estomas con calidez humana." },
  { title: "Diálisis Peritoneal", slug: "dialisis-peritoneal", img: "dialisis-peritoneal.webp", desc: "Conexión y desconexión segura bajo estrictos protocolos de bioseguridad." },
  { title: "Sueroterapia Post Party", slug: "sueroterapia-post-party", img: "post-party.webp", desc: "Recuperación rápida y efectiva tras deshidratación o desgaste físico." },
];
---

<section id="servicios" class="py-14 bg-slate-50 overflow-hidden relative">
  <!-- ENCABEZADO -->
  <div class="container mx-auto px-6 text-center mb-10">
    <h2 class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight uppercase">
      Servicios de Enfermería
    </h2>
    <p class="text-lg md:text-xl text-slate-600 max-w-3xl mx-auto font-medium leading-relaxed">
      Atención profesional y humanizada en Bucaramanga y su área metropolitana.
    </p>
  </div>

  <div class="relative max-w-[1440px] mx-auto px-4 md:px-16">
    
    <!-- MÓVIL: MANO GESTUAL (Solo visible en < md) -->
    <div id="swipe-hint" class="md:hidden absolute right-10 top-20 z-50 pointer-events-none flex flex-col items-center gap-2 transition-all duration-700">
      <div class="bg-blue-600 text-white p-3 rounded-full shadow-2xl animate-[pulse_1.5s_infinite]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v5" />
            <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v10" />
            <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8" />
            <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15" />
        </svg>
      </div>
      <span class="text-[10px] font-black uppercase text-blue-700 bg-white/90 px-3 py-1 rounded-full shadow-sm border border-blue-100">Desliza</span>
    </div>

    <!-- ESCRITORIO: FLECHAS (Solo visibles en >= md) -->
    <button id="prev-btn" class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 z-40 w-12 h-12 items-center justify-center bg-white border border-slate-200 rounded-full shadow-lg hover:bg-blue-600 hover:text-white transition-all active:scale-90 group" aria-label="Anterior">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button id="next-btn" class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 z-40 w-12 h-12 items-center justify-center bg-white border border-slate-200 rounded-full shadow-lg hover:bg-blue-600 hover:text-white transition-all active:scale-90 group" aria-label="Siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- TRACK DEL CARRUSEL -->
    <div
      id="carousel-track"
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-10 cursor-grab active:cursor-grabbing scroll-smooth"
    >
      {services.map((s) => (
        <div class="min-w-[88%] sm:min-w-[50%] md:min-w-[31.5%] snap-center">
          <div class="bg-white rounded-[2rem] border border-slate-200 overflow-hidden shadow-sm flex flex-col h-full hover:shadow-xl transition-all duration-500">
            
            <!-- IMAGEN CON BOTÓN -->
            <div class="relative h-52 md:h-60 overflow-hidden group">
              <img src={`${import.meta.env.BASE_URL}/img/services/${s.img}`} alt={s.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
              
              <div class="absolute inset-x-0 bottom-5 flex justify-center px-4">
                <a href={`/enfermerosBucaramanga/services/${s.slug}`} class="bg-white text-blue-800 text-[11px] font-black uppercase tracking-[0.15em] py-3.5 px-10 rounded-2xl shadow-2xl hover:bg-blue-600 hover:text-white transition-all active:scale-95 border border-white">
                  Ver Detalles
                </a>
              </div>
            </div>

            <!-- CONTENIDO (Fuente aumentada para adultos mayores) -->
            <div class="p-8 text-left bg-white flex-grow">
              <h3 class="text-2xl font-bold text-slate-800 leading-tight mb-4">{s.title}</h3>
              <p class="text-slate-600 text-base md:text-lg leading-relaxed line-clamp-3 md:line-clamp-none">
                {s.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- BARRA DE PROGRESO -->
    <div class="flex justify-center -mt-2">
      <div class="w-full max-w-[150px] h-2 bg-slate-200 rounded-full overflow-hidden border border-slate-300/20">
        <div id="scroll-progress" class="h-full bg-blue-600 w-0 transition-all duration-300 rounded-full shadow-[0_0_10px_rgba(37,99,235,0.4)]"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  const track = document.getElementById('carousel-track');
  const progress = document.getElementById('scroll-progress');
  const hint = document.getElementById('swipe-hint');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');
  const section = document.getElementById('servicios');

  if (track) {
    // 1. Lógica de Scroll (Progreso y Ocultar Mano)
    track.addEventListener('scroll', () => {
      const maxScroll = track.scrollWidth - track.clientWidth;
      const percentage = (track.scrollLeft / maxScroll) * 100;
      if (progress) progress.style.width = `${percentage}%`;

      if (track.scrollLeft > 30 && hint) {
        hint.style.opacity = '0';
        hint.style.transform = 'translateX(20px)';
        setTimeout(() => hint.remove(), 700);
      }
    });

    // 2. Lógica de Botones (Escritorio)
    const getCardWidth = () => track.querySelector('.snap-center').clientWidth + 24; // Card + gap
    
    nextBtn?.addEventListener('click', () => {
      track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
    });

    prevBtn?.addEventListener('click', () => {
      track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
    });

    // 3. Micro-rebote (Móvil) al entrar en vista
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            if (track.scrollLeft === 0) {
              track.scrollBy({ left: 80, behavior: 'smooth' });
              setTimeout(() => track.scrollBy({ left: -80, behavior: 'smooth' }), 600);
            }
          }, 800);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    if (section) observer.observe(section);
  }
</script>