---
const services = [
  { title: "Curaciones", slug: "curaciones", img: "curaciones.webp", desc: "Cambio de apósitos, manejo de heridas quirúrgicas y cuidados especializados." },
  { title: "Inyectología", slug: "inyectologia", img: "inyectologia.webp", desc: "Aplicación segura de medicamentos intramusculares y subcutáneos." },
  { title: "Paso de Sueros", slug: "paso-de-sueros", img: "paso-de-sueros.webp", desc: "Hidratación y medicación intravenosa con monitoreo profesional." },
  { title: "Nebulizaciones", slug: "nebulizaciones", img: "nebulizaciones.webp", desc: "Terapia respiratoria para asma, EPOC y otras afecciones pulmonares." },
  { title: "Retiro de Puntos", slug: "retiro-de-puntos", img: "retiro-de-puntos.webp", desc: "Remoción segura de suturas con evaluación de cicatrización." },
  { title: "Paso de Sondas", slug: "sondas-vesicales", img: "paso-de-sondas.webp", desc: "Técnica estéril en sondas vesicales y gástricas con manejo profesional." },
  { title: "Manejo de Colostomías", slug: "colostomias", img: "manejo-de-colostomias.webp", desc: "Cuidado especializado de colostomías con enfoque humanizado." },
  { title: "Diálisis Peritoneal", slug: "dialisis-peritoneal", img: "dialisis-peritoneal.webp", desc: "Conexión y desconexión segura con técnica estéril en su hogar." },
  { title: "Sueroterapia Post Party", slug: "sueroterapia-post-party", img: "post-party.webp", desc: "Hidratación intravenosa rápida para recuperación tras deshidratación o excesos." },
];
---

<section id="servicios" class="py-20 bg-slate-50 overflow-hidden relative" aria-labelledby="servicios-title">
  <div class="container mx-auto px-6 text-center mb-16">
    <h2 id="servicios-title" class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight">
      Servicios de Enfermería
    </h2>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto font-medium text-balance">
      Atención profesional y humanizada en Piedecuesta y área metropolitana.
    </p>
  </div>

  <div class="relative max-w-[1400px] mx-auto">
    
    <div id="swipe-hint" class="md:hidden absolute right-8 top-[40%] -translate-y-1/2 z-50 pointer-events-none flex flex-col items-center gap-3 transition-all duration-700 ease-in-out">
      <div class="bg-blue-600/90 backdrop-blur-md text-white p-5 rounded-full shadow-2xl animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
      <span class="text-[11px] font-black uppercase tracking-[0.3em] text-blue-700 bg-white/90 px-4 py-1.5 rounded-full shadow-sm border border-blue-100">Desliza</span>
    </div>

    <button id="prev-btn" class="hidden md:flex absolute left-4 top-[40%] z-30 w-14 h-14 items-center justify-center bg-white border border-slate-200 rounded-full shadow-lg hover:bg-blue-600 hover:text-white transition-all duration-300 group" aria-label="Anterior">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform group-active:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <div
      id="carousel-track"
      class="flex gap-5 md:gap-8 overflow-x-auto snap-x snap-mandatory scrollbar-hide px-6 md:px-20 pb-20 cursor-grab active:cursor-grabbing"
    >
      {services.map((s) => (
        <div class="min-w-[82%] sm:min-w-[55%] md:min-w-[40%] lg:min-w-[30%] snap-center group">
          <div class="h-full bg-white rounded-3xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col group-hover:-translate-y-2 transform-gpu">
            
            <div class="relative h-64 overflow-hidden">
              <img 
                src={`${import.meta.env.BASE_URL}/img/services/${s.img}`} 
                alt={s.title}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
            </div>

            <div class="p-8 md:p-10 flex flex-col flex-grow text-left">
              <h3 class="text-2xl font-bold text-slate-800 mb-4 group-hover:text-blue-600 transition-colors leading-tight">
                {s.title}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed mb-10 flex-grow line-clamp-3 md:line-clamp-none">
                {s.desc}
              </p>
              
              <a 
                href={`/enfermerosBucaramanga/services/${s.slug}`}
                class="inline-flex items-center justify-center w-full py-4 px-6 bg-slate-100 text-blue-700 font-black rounded-2xl text-xs uppercase tracking-widest hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-sm active:scale-95 border border-slate-200 hover:border-transparent"
              >
                Ver Detalles
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <button id="next-btn" class="hidden md:flex absolute right-4 top-[40%] z-30 w-14 h-14 items-center justify-center bg-white border border-slate-200 rounded-full shadow-lg hover:bg-blue-600 hover:text-white transition-all duration-300 group" aria-label="Siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform group-active:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <div class="px-6">
      <div class="max-w-xs mx-auto h-2 bg-slate-200 rounded-full overflow-hidden shadow-inner border border-slate-300/20">
        <div id="scroll-progress" class="h-full bg-blue-600 w-0 transition-all duration-300 ease-out rounded-full shadow-[0_0_8px_rgba(37,99,235,0.5)]"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  const track = document.getElementById('carousel-track');
  const progress = document.getElementById('scroll-progress');
  const hint = document.getElementById('swipe-hint');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');

  if (track) {
    track.addEventListener('scroll', () => {
      const maxScroll = track.scrollWidth - track.clientWidth;
      const percentage = (track.scrollLeft / maxScroll) * 100;
      if (progress) progress.style.width = `${percentage}%`;

      if (track.scrollLeft > 30 && hint) {
        hint.style.opacity = '0';
        hint.style.transform = 'translateY(-50%) scale(0.6)';
        setTimeout(() => hint.remove(), 700);
      }
    });

    const scrollAmount = () => track.querySelector('.snap-center').clientWidth + 24;
    nextBtn?.addEventListener('click', () => track.scrollBy({ left: scrollAmount(), behavior: 'smooth' }));
    prevBtn?.addEventListener('click', () => track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' }));

    // MICRO-REBOTE AL CARGAR
    window.addEventListener('load', () => {
      setTimeout(() => {
        if (track.scrollLeft === 0) {
          track.scrollBy({ left: 60, behavior: 'smooth' });
          setTimeout(() => {
            track.scrollBy({ left: -60, behavior: 'smooth' });
          }, 600);
        }
      }, 1800);
    });
  }
</script>